{
  "name": "@cottagehop/here-be-dragons",
  "version": "0.2.0",
  "description": "Maps for the parts where 'here be dragons' got written — a stylized 3D vector-tile renderer with toon shading, sketch outlines, and a dozen swappable themes.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode lib && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "build:demo": "vite build",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cottagehop/HereBeDragons.git"
  },
  "homepage": "https://github.com/cottagehop/HereBeDragons#readme",
  "bugs": {
    "url": "https://github.com/cottagehop/HereBeDragons/issues"
  },
  "author": "Robert Catmull <robert.catmull@realtorhop.com>",
  "peerDependencies": {
    "three": ">=0.170.0 <1.0.0"
  },
  "dependencies": {
    "@mapbox/vector-tile": "^2.0.4",
    "earcut": "^3.0.2",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.1"
  },
  "devDependencies": {
    "@types/earcut": "^3.0.0",
    "@types/node": "^22.19.18",
    "@types/three": "^0.184.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "three": "^0.184.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "3d",
    "map",
    "cartography",
    "vector-tiles",
    "pmtiles",
    "mvt",
    "three.js",
    "threejs",
    "webgl",
    "typescript",
    "stylized",
    "toon-shading",
    "sketch",
    "themeable"
  ],
  "license": "SEE LICENSE IN LICENSE"
}
